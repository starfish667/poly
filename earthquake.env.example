POLYMARKET_PRIVATE_KEY=
POLYMARKET_WALLET_ADDRESS=

# Live trading still requires run_earthquake_trigger_live.sh, which sets this to 1.
POLYBOT_ENABLE_LIVE=0

POLYBOT_EARTHQUAKE_EVENT_URL=https://polymarket.com/event/how-many-6pt5-or-above-earthquakes-july-6-july-12-20260702194353908
POLYBOT_EARTHQUAKE_INTERVAL=0.5
POLYBOT_EARTHQUAKE_MARKET_REFRESH_INTERVAL=60

# Usually inferred from the Polymarket rules text. Set these only when inference fails
# or when watching another event with unusual wording.
# POLYBOT_EARTHQUAKE_MIN_MAGNITUDE=6.5
# POLYBOT_EARTHQUAKE_START_UTC=2026-07-06T04:00:00Z
# POLYBOT_EARTHQUAKE_END_UTC=2026-07-13T03:59:00Z

# all = fastest; reviewed = safer but may lag.
POLYBOT_EARTHQUAKE_REVIEW_STATUS=all

# 1 means buy already-impossible lower count NO markets immediately at startup.
# 0 means establish a baseline and wait for the next count increase.
POLYBOT_EARTHQUAKE_TRADE_ON_START=0

# After the event window ends, wait this long before buying the final YES.
POLYBOT_EARTHQUAKE_SETTLEMENT_DELAY_SECONDS=30
POLYBOT_EARTHQUAKE_SETTLEMENT_UPDATE_MIN_AGE_SECONDS=30

POLYBOT_EARTHQUAKE_MAX_NO_ENTRY_PRICE=0.99
POLYBOT_EARTHQUAKE_NO_LIMIT_PRICE=0.99
POLYBOT_EARTHQUAKE_NO_SIZE=5

POLYBOT_EARTHQUAKE_MAX_YES_ENTRY_PRICE=0.99
POLYBOT_EARTHQUAKE_YES_LIMIT_PRICE=0.99
POLYBOT_EARTHQUAKE_YES_SIZE=5

POLYBOT_EARTHQUAKE_PRICE_WEBSOCKET_MAX_AGE=10
POLYBOT_EARTHQUAKE_PRICE_WAIT_SECONDS=2

# One-command tmux launcher.
POLYBOT_EC2_USER=ec2-user
# POLYBOT_PROJECT_DIR=/home/ec2-user/polymarket
POLYBOT_EARTHQUAKE_TMUX_SESSION=earthquake-trigger
POLYBOT_EARTHQUAKE_TMUX_MODE=live
# restart = replace an existing same-name session; start = leave it alone; attach = attach only.
POLYBOT_EARTHQUAKE_TMUX_ACTION=restart
POLYBOT_EARTHQUAKE_TMUX_ATTACH=1

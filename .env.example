POLYMARKET_PRIVATE_KEY=
POLYMARKET_WALLET_ADDRESS=

POLYBOT_ENABLE_LIVE=0
POLYBOT_INTERVAL=15
POLYBOT_ACTIVE_INTERVAL=3
POLYBOT_MAX_CONCURRENCY=4
POLYBOT_WEATHER_INTERVAL=15
POLYBOT_WEATHER_ACTIVE_INTERVAL=0.5
POLYBOT_WEATHER_MAX_CONCURRENCY=6
POLYBOT_PRICE_WEBSOCKET=1
POLYBOT_PRICE_WEBSOCKET_MAX_AGE=10
EARNINGS_SEC_LOOKAHEAD_DAYS=2

AVIATION_WEATHER_HOURS=72
AVIATION_WEATHER_CACHE_SECONDS=2
# Leave unset for multi-city weather. Set only to force one timezone.
# WEATHER_LOCAL_TZ=Asia/Shanghai

# Dedicated same-day temperature trigger bot.
POLYBOT_TRIGGER_CITY_COUNT=8
POLYBOT_TRIGGER_INTERVAL=0.5
POLYBOT_TRIGGER_DISCOVERY_INTERVAL=60
POLYBOT_TRIGGER_MIN_LIQUIDITY=100
POLYBOT_TRIGGER_MAX_EVENT_VOLUME=50000
# Optional upper liquidity cap to avoid crowded markets.
# POLYBOT_TRIGGER_MAX_EVENT_LIQUIDITY=20000
POLYBOT_TRIGGER_MAX_ENTRY_PRICE=0.99
POLYBOT_TRIGGER_LIMIT_PRICE=0.99
POLYBOT_TRIGGER_SIZE=5
POLYBOT_TRIGGER_SOURCE=auto
POLYBOT_TRIGGER_PRICE_WEBSOCKET_MAX_AGE=10
POLYBOT_TRIGGER_PRICE_WAIT_SECONDS=2
# Set to 1 only if startup should immediately trade already-observed highs.
POLYBOT_TRIGGER_TRADE_ON_START=0

# SEC prefers a real contact in the user agent.
SEC_USER_AGENT=polymarket-event-bot/1.0-contact-your_email@example.com
